# Copy this file to `.env` and fill in real values.

# ── MySQL ────────────────────────────────────────────────────────────────
# Read by server/utils/db.ts at startup.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=rc

# Pool size. 10 is comfortable for a single-user local app.
DB_CONNECTION_LIMIT=10


# ── Auth ─────────────────────────────────────────────────────────────────
# Signing key for JWT access tokens. MUST be at least 16 characters and
# kept secret — leaking it lets an attacker mint admin tokens. Generate one
# with: `openssl rand -base64 48`
JWT_SECRET=replace-me-with-a-long-random-string

# Seed admin created by `npm run migrate:auth`. Pick any password you like;
# you can change it later through the app once logged in. The migration is
# idempotent — once the user exists these are ignored.
ADMIN_INITIAL_EMAIL=admin@local
ADMIN_INITIAL_PASSWORD=
ADMIN_INITIAL_NAME=Administrator


# ── SMTP (optional) ──────────────────────────────────────────────────────
# Used to send email-verification links. If any of the three required
# fields is blank, the mailer falls back to printing the email to the
# server console so you can copy the verification link by hand in dev.
#
# For Gmail: use an "App password" (Google account → Security → App
# passwords), NOT your normal account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false


# ── App ──────────────────────────────────────────────────────────────────
# Where this app is reachable from the user's browser. Used to build the
# absolute URL inside verification emails. The port is omitted from the
# rendered URL when it matches the protocol default (80 for http, 443 for
# https). `APP_PROTOCOL` is optional and defaults to `http`.
APP_HOST=localhost
APP_PORT=3000
# APP_PROTOCOL=http
